# ─── SITE ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://audiovisualnepal.com

# ─── WORDPRESS BACKEND ───────────────────────────────────────────────────────
# URL of the WordPress installation (where the REST API lives)
# The /wp-json endpoint must be accessible at this URL
NEXT_PUBLIC_WP_URL=https://audiovisualnepal.com

# WordPress Application Password (optional — only needed for private/draft content)
# Generate at: WP Admin → Users → Your Profile → Application Passwords
# WP_API_USER=your_wp_username
# WP_API_TOKEN=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── ANALYTICS (optional) ────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
